---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Refuge & Sword Publishing',
  description = 'A Christ-centered publishing house producing apps, books, and podcasts rooted in truth, wisdom, and conviction.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/images/logo.png" />
  </head>
  <body>
    <slot />
  </body>
</html>
