---
const year = new Date().getFullYear();
---

<footer style="background-color: var(--midnight-navy); color: var(--warm-sand);">
  <div class="max-w-5xl mx-auto px-6 py-12 flex flex-col items-center gap-4 text-center">
    <div class="gold-divider"></div>
    <p class="font-editorial italic text-lg" style="color: var(--heritage-gold);">
      "Build Something Worth Keeping."
    </p>
    <p class="text-sm tracking-wide" style="color: var(--slate-gray);">
      &copy; {year} Refuge &amp; Sword Publishing LLC &middot; refugeandsword.com
    </p>
  </div>
</footer>
