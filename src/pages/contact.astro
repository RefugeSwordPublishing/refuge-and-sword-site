---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Contact | Refuge & Sword Publishing"
  description="Get in touch with Refuge & Sword Publishing."
>
  <Nav />

  <main class="min-h-screen py-24 px-6" style="background-color: var(--stone-white);">
    <div class="max-w-2xl mx-auto flex flex-col items-center gap-8">

      <div class="flex flex-col items-center text-center gap-4">
        <p class="text-xs tracking-[0.25em] uppercase" style="color: var(--heritage-gold);">Contact</p>
        <h1 class="text-3xl md:text-4xl" style="color: var(--deep-forest);">Get in Touch</h1>
        <div class="gold-divider"></div>
        <p class="text-base leading-relaxed max-w-md" style="color: var(--slate-gray);">
          Have a manuscript, a ministry idea, or a general question? We read every message
          and will get back to you as soon as we can.
        </p>
      </div>

      <!-- Tally Form -->
      <div class="w-full rounded-lg overflow-hidden shadow-sm" style="background-color: var(--stone-white);">
        <iframe
          data-tally-src="https://tally.so/embed/eqob1o?alignLeft=1&hideTitle=1&transparentBackground=1&dynamicHeight=1"
          loading="lazy"
          width="100%"
          height="400"
          frameborder="0"
          marginheight="0"
          marginwidth="0"
          title="Contact Refuge & Sword Publishing"
        ></iframe>
        <script>
          var d=document,w="https://tally.so/widgets/embed.js",v=function(){"undefined"!=typeof Tally?Tally.loadEmbeds():d.querySelectorAll("iframe[data-tally-src]:not([src])").forEach((function(e){e.src=e.dataset.tallySrc}))};if("undefined"!=typeof Tally)v();else if(d.querySelector('script[src="'+w+'"]')==null){var s=d.createElement("script");s.src=w,s.onload=v,s.onerror=v,d.body.appendChild(s);}
        </script>
      </div>

      <p class="text-xs text-center" style="color: var(--warm-sand);">
        You can also reach us at
        <a href="mailto:dustin@refugeandsword.com" style="color: var(--heritage-gold);">
          dustin@refugeandsword.com
        </a>
      </p>

    </div>
  </main>

  <Footer />
</Layout>
