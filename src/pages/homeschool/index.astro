// ─── TREE VIEW ────────────────────────────────────────────────────────────────
function TreeView({ subject, nodes, statuses, selectedNode, setSelectedNode, setProgress, childProgress, masteredCount, child, editMode, onEditNode, data, passingThreshold, onSaveQuestions, onAddCustomNode, activeSubject }) {
  const maxCol = Math.max(...nodes.map(n=>n.col), 0);
  const maxRow = Math.max(...nodes.map(n=>n.row), 0);
  const svgW = PAD_X*2 + (maxCol+1)*(NODE_W+COL_GAP) - COL_GAP;
  const svgH = PAD_Y*2 + (maxRow+1)*(NODE_H+ROW_GAP) - ROW_GAP;

  const nodeMap = useMemo(() => { const m={}; for(const n of nodes) m[n.id]=n; return m; }, [nodes]);

  const edges = useMemo(() => {
    const result = [];
    for (const node of nodes) {
      for (const pid of node.prereqs) {
        const prereq = nodeMap[pid];
        if (!prereq) continue;
        const lit = statuses[pid]===STATUS.MASTERED && statuses[node.id]===STATUS.MASTERED;
        result.push({ id:`${pid}-${node.id}`, path:buildEdgePath(prereq, node), lit });
      }
    }
    return result;
  }, [nodes, statuses, nodeMap]);

  const handleClick = (node) => {
    if (editMode) { onEditNode(node.id); return; }
    if (statuses[node.id]===STATUS.LOCKED) return;
    setSelectedNode(prev => prev?.id===node.id ? null : node);
