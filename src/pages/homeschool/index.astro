              activeChild===c.id && React.createElement("button", { onClick:()=>startEditChild(c), title:"Rename", style:{ padding:"6px 10px 6px 6px", borderRadius:"0 20px 20px 0", border:"none", background:c.color, color:"rgba(255,255,255,0.75)", cursor:"pointer", fontSize:11 } }, "✎")
