            React.createElement("input", { value:newNodeGrade, onChange:e=>setNewNodeGrade(e.target.value), placeholder:"Grade (e.g. 3–4)", style:{ padding:"7px 12px", borderRadius:10, border:"1px solid rgba(255,255,255,0.2)", background:"rgba(255,255,255,0.08)", color:"#fff", fontSize:13, width:130 } }),
            React.createElement("button", { onClick:submitNewNode, style:{ padding:"7px 16px", borderRadius:10, border:"none", background:"#4A6FA5", color:"#fff", fontSize:13, cursor:"pointer" } }, "Add"),
