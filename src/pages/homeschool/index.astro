  const [addingNode, setAddingNode] = useState(false);
  const [newNodeLabel, setNewNodeLabel] = useState("");
  const [newNodeGrade, setNewNodeGrade] = useState("");

  const submitNewNode = () => {
    if (!newNodeLabel.trim()) return;
    const id = "custom_" + Date.now();
    const newRow = maxRow + 1;
    onAddCustomNode(activeSubject, { id, label: newNodeLabel.trim(), grade: newNodeGrade.trim() || "?", prereqs: [], col: 0, row: newRow, desc: "" });
    setNewNodeLabel(""); setNewNodeGrade(""); setAddingNode(false);
