---
const SUPABASE_URL = import.meta.env.SUPABASE_URL ?? "";
const SUPABASE_ANON_KEY = import.meta.env.SUPABASE_ANON_KEY ?? "";
---

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Homeschool Path — Refuge &amp; Sword</title>
<meta name="robots" content="noindex, nofollow" />
<script src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
<script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
<script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html, body { height: 100%; background: #0F1117; color: #E8EAF0; font-family: 'Inter', 'Segoe UI', sans-serif; }
  #root { height: 100%; }
  #gate { display:flex; flex-direction:column; align-items:center; justify-content:center; min-height:100vh; gap:20px; }
  #gate .logo { font-size:13px; color:rgba(255,255,255,0.3); letter-spacing:0.08em; text-transform:uppercase; margin-bottom:8px; }
  #gate h1 { font-size:22px; font-weight:700; color:#fff; }
  #gate p { font-size:13px; color:rgba(255,255,255,0.4); }
  #gate input { padding:10px 16px; border-radius:10px; border:1px solid rgba(255,255,255,0.15); background:rgba(255,255,255,0.07); color:#fff; font-size:15px; width:240px; text-align:center; }
  #gate input:focus { outline:none; border-color:rgba(255,255,255,0.35); }
  #gate button { padding:10px 28px; border-radius:10px; border:none; background:#4A6FA5; color:#fff; font-size:14px; font-weight:600; cursor:pointer; }
  #gate .error { color:rgba(255,100,100,0.8); font-size:13px; }
  ::-webkit-scrollbar { width:6px; height:6px; }
  ::-webkit-scrollbar-track { background:rgba(255,255,255,0.03); }
  ::-webkit-scrollbar-thumb { background:rgba(255,255,255,0.18); border-radius:3px; }
  input:focus, textarea:focus { outline:none; }
  button:focus-visible { outline:2px solid rgba(255,255,255,0.4); outline-offset:2px; }
  @keyframes hs-pulse { 0%,100%{opacity:.75;} 50%{opacity:1;} }
  @keyframes hs-spin { to{transform:rotate(360deg);} }
  .hs-inprog-rect { animation: hs-pulse 2.2s ease-in-out infinite; }
  .hs-tree-bg {
    background-image: radial-gradient(circle, rgba(255,255,255,0.04) 1px, transparent 1px);
    background-size: 28px 28px;
  }
</style>
</head>
<body>

<div id="gate">
  <div class="logo">Refuge &amp; Sword</div>
  <h1>Homeschool Path</h1>
  <p id="gate-sub">Sign in to continue.</p>
  <input type="email" id="email-input" placeholder="Email" autocomplete="email" />
  <input type="password" id="pw-input" placeholder="Password" autocomplete="current-password" />
  <button id="pw-submit">Sign In</button>
  <div class="error" id="pw-error" style="display:none">Incorrect email or password.</div>
  <div id="gate-loading" style="display:none;font-size:13px;color:rgba(255,255,255,0.35)">Signing in...</div>
</div>

<div id="root" style="display:none;height:100%"></div>

<!-- Stash credentials in window vars via define:vars, then load Supabase dynamically -->
<script is:inline define:vars={{ SUPABASE_URL, SUPABASE_ANON_KEY }}>
  window._SB_URL = SUPABASE_URL;
  window._SB_KEY = SUPABASE_ANON_KEY;
</script>

<script is:inline>
  function unlock() {
    document.getElementById("gate").style.display = "none";
    document.getElementById("root").style.display = "block";
  }

  function showError(msg) {
    var el = document.getElementById("pw-error");
    el.textContent = msg;
    el.style.display = "block";
    document.getElementById("gate-loading").style.display = "none";
    document.getElementById("pw-submit").disabled = false;
  }

  function attemptLogin() {
    if (!window.HS_DB) { showError("Still loading — please wait a moment and try again."); return; }
    var email = document.getElementById("email-input").value.trim();
    var password = document.getElementById("pw-input").value;
    if (!email || !password) { showError("Please enter your email and password."); return; }
    document.getElementById("pw-submit").disabled = true;
    document.getElementById("gate-loading").style.display = "block";
    document.getElementById("pw-error").style.display = "none";
    window.HS_DB.auth.signInWithPassword({ email: email, password: password })
      .then(function(r) {
        if (r.error) showError(r.error.message);
        else unlock();
      })
      .catch(function(e) { showError(e.message || "Sign in failed."); });
  }

  document.getElementById("pw-submit").addEventListener("click", attemptLogin);
  document.getElementById("pw-input").addEventListener("keydown", function(e) { if (e.key === "Enter") attemptLogin(); });
  document.getElementById("email-input").addEventListener("keydown", function(e) { if (e.key === "Enter") document.getElementById("pw-input").focus(); });

  if (!window._SB_URL) {
    showError("SUPABASE_URL is not configured — check Vercel env vars.");
  } else {
    var sbScript = document.createElement("script");
    sbScript.src = "https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.js";
    sbScript.onload = function() {
      try {
        window.HS_DB = supabase.createClient(window._SB_URL, window._SB_KEY, {
          auth: { persistSession: true, autoRefreshToken: true, detectSessionInUrl: false }
        });
        // onAuthStateChange fires immediately with the restored session (if any),
        // then again on login/logout/token-refresh — covers all cases in one handler
        window.HS_DB.auth.onAuthStateChange(function(event, session) {
          if (session && event !== 'SIGNED_OUT') {
            var gate = document.getElementById('gate');
            if (gate && gate.style.display !== 'none') unlock();
          }
        });
      } catch(e) { showError("Init error: " + e.message); }
    };
    sbScript.onerror = function() { showError("Could not load Supabase library — check your internet connection."); };
    document.head.appendChild(sbScript);
  }
</script>

<!-- Curriculum data: tests, resources, updated colors. Loaded before React. -->
<script is:inline src="/curriculum-data.js"></script>

