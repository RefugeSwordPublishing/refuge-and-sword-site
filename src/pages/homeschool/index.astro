const STATUS = { LOCKED: "locked", UNLOCKED: "unlocked", IN_PROGRESS: "in_progress", MASTERED: "mastered" };
const STATUS_LABELS = { locked: "Locked", unlocked: "Ready to Learn", in_progress: "In Progress", mastered: "Mastered" };

const NODE_W = 152;
const NODE_H = 64;
const COL_GAP = 48;
const ROW_GAP = 44;
const PAD_X = 32;
const PAD_Y = 24;

function getNodePos(node) {
  return {
    x: PAD_X + node.col * (NODE_W + COL_GAP),
    y: PAD_Y + node.row * (NODE_H + ROW_GAP),
  };
}

function buildEdgePath(srcNode, tgtNode, allNodes) {
  const src = getNodePos(srcNode);
  const tgt = getNodePos(tgtNode);
  const x1 = src.x + NODE_W / 2;
  const y1 = src.y + NODE_H;
  const x2 = tgt.x + NODE_W / 2;
  const y2 = tgt.y;
  const laneY = y1 + (y2 - y1) * 0.5;
  if (srcNode.col === tgtNode.col) {
    const cy = (y1 + y2) / 2;
    return `M${x1},${y1} C${x1},${cy} ${x2},${cy} ${x2},${y2}`;
  }
  const r = 8;
  const goRight = x2 > x1;
  const hDir = goRight ? 1 : -1;
  const downEnd = laneY - r;
  const horizStart = x1 + hDir * r;
  const horizEnd = x2 - hDir * r;
  const upStart = laneY + r;
  return [
    `M${x1},${y1}`,
    `L${x1},${downEnd}`,
    `Q${x1},${laneY} ${horizStart},${laneY}`,
    `L${horizEnd},${laneY}`,
    `Q${x2},${laneY} ${x2},${upStart}`,
    `L${x2},${y2}`,
  ].join(" ");
}

function computeStatuses(nodes, progress) {
  const mastered = new Set(
    Object.entries(progress)
      .filter(([k, v]) => v === STATUS.MASTERED && !k.includes("_log"))
      .map(([k]) => k)
  );
  const result = {};
  for (const node of nodes) {
    const existing = progress[node.id];
    if (existing === STATUS.MASTERED) { result[node.id] = STATUS.MASTERED; continue; }
    if (existing === STATUS.IN_PROGRESS) { result[node.id] = STATUS.IN_PROGRESS; continue; }
    result[node.id] = node.prereqs.every(p => mastered.has(p)) ? STATUS.UNLOCKED : STATUS.LOCKED;
  }
  return result;
}

function statusColor(status, subject) {
  if (status === STATUS.MASTERED) return subject.color;
  if (status === STATUS.IN_PROGRESS) return subject.accent;
  if (status === STATUS.UNLOCKED) return "#4A5568";
  return "#2D3748";
}

function statusBg(status) {
  if (status === STATUS.MASTERED) return "rgba(255,255,255,0.15)";
  if (status === STATUS.IN_PROGRESS) return "rgba(255,255,255,0.09)";
  if (status === STATUS.UNLOCKED) return "rgba(255,255,255,0.06)";
  return "rgba(255,255,255,0.02)";
}

