        ),
        React.createElement("div", { style:{ fontSize:28, fontWeight:800, color:subject.accent, lineHeight:1 } }, `${pct}%`),
      ),
      React.createElement("div", { style:{ height:10, borderRadius:5, background:"rgba(255,255,255,0.1)", overflow:"hidden" } },
        React.createElement("div", { style:{ height:"100%", borderRadius:5, transition:"width 0.6s cubic-bezier(.4,0,.2,1)", width:`${pct}%`, background:`linear-gradient(90deg, ${subject.color}, ${subject.accent})`, boxShadow:`0 0 10px ${subject.color}80` } })
      )
    ),

    editMode && React.createElement("div", { style:{ marginBottom:12, padding:"8px 16px", borderRadius:8, background:"rgba(255,200,80,0.08)", border:"1px solid rgba(255,200,80,0.25)", fontSize:12, color:"rgba(255,200,80,0.85)", fontWeight:600 } },
      "✎ Edit mode — tap any node to edit it"
    ),

    // Legend
    React.createElement("div", { style:{ display:"flex", gap:8, marginBottom:14, fontSize:11, flexWrap:"wrap", justifyContent:"center" } },
      [STATUS.LOCKED, STATUS.UNLOCKED, STATUS.IN_PROGRESS, STATUS.MASTERED].map(s =>
        React.createElement("div", { key:s, style:{ display:"flex", alignItems:"center", gap:5, padding:"3px 10px", borderRadius:20, background:"rgba(255,255,255,0.04)", color:"rgba(255,255,255,0.45)" } },
          React.createElement("div", { style:{ width:8, height:8, borderRadius:"50%", background:statusColor(s,subject) } }),
          STATUS_LABELS[s]
        )
      )
    ),

    // SVG Tree
    React.createElement("div", { className:"hs-tree-bg", style:{ overflowX:"auto", overflowY:"auto", maxWidth:"100vw", maxHeight: IS_MOBILE?"68vh":"62vh", borderRadius: IS_MOBILE?12:16, border:`1px solid ${subject.color}25`, background:`radial-gradient(ellipse at 50% 0%, ${subject.color}12 0%, transparent 60%), rgba(8,12,28,0.7)`, WebkitOverflowScrolling:"touch" } },
      React.createElement("svg", { width:svgW, height:svgH, style:{ display:"block" } },
        React.createElement("defs", null,
          React.createElement("marker", { id:"arr", markerWidth:7, markerHeight:7, refX:3.5, refY:3.5, orient:"auto" }, React.createElement("path", { d:"M0,0 L7,3.5 L0,7 Z", fill:"rgba(255,255,255,0.18)" })),
          React.createElement("marker", { id:"arr-lit", markerWidth:8, markerHeight:8, refX:4, refY:4, orient:"auto" }, React.createElement("path", { d:"M0,0 L8,4 L0,8 Z", fill:subject.accent })),
          React.createElement("filter", { id:"node-glow", x:"-30%", y:"-30%", width:"160%", height:"160%" },
            React.createElement("feGaussianBlur", { stdDeviation:"5", result:"blur" }),
            React.createElement("feMerge", null,
              React.createElement("feMergeNode", { in:"blur" }),
              React.createElement("feMergeNode", { in:"SourceGraphic" }),
            )
          ),
        ),
        ...edges.map(e => React.createElement("path", { key:e.id, d:e.path, fill:"none", stroke:e.lit?subject.accent:"rgba(255,255,255,0.1)", strokeWidth:e.lit?2.5:1.5, strokeDasharray:e.lit?"none":"6 5", markerEnd:e.lit?"url(#arr-lit)":"url(#arr)", opacity:e.lit?0.9:0.4 })),
        ...nodes.map(node => {
          const { x, y } = getNodePos(node);
          const status = statuses[node.id];
          const isSelected = selectedNode?.id===node.id;
          const locked = status===STATUS.LOCKED && !editMode;
          const fill = statusFill(status, subject);
          const stroke = editMode ? "rgba(255,200,80,0.6)" : statusStroke(status, subject);
          const txtColor = statusTextColor(status);
          const hasTest = getNodeAllTests(node, data.questions||{}).length > 0;
          const isMastered = status===STATUS.MASTERED;
          const isInProg = status===STATUS.IN_PROGRESS;

          return React.createElement("g", { key:node.id, onClick:()=>handleClick(node), style:{ cursor:locked?"default":"pointer", opacity:locked?0.4:1 } },
            // Glow ring for mastered
            isMastered && React.createElement("rect", { x:x-6, y:y-6, width:NODE_W+12, height:NODE_H+12, rx:18, ry:18, fill:"none", stroke:subject.accent, strokeWidth:2, opacity:0.3, filter:"url(#node-glow)" }),
            // Selection ring
            isSelected && React.createElement("rect", { x:x-5, y:y-5, width:NODE_W+10, height:NODE_H+10, rx:17, ry:17, fill:"none", stroke:"#fff", strokeWidth:2, opacity:0.5 }),
            // Edit mode ring
            editMode && React.createElement("rect", { x:x-3, y:y-3, width:NODE_W+6, height:NODE_H+6, rx:15, ry:15, fill:"none", stroke:"rgba(255,200,80,0.5)", strokeWidth:1.5 }),
            // Main node body
            React.createElement("rect", {
              x, y, width:NODE_W, height:NODE_H, rx:14, ry:14,
              fill, stroke, strokeWidth:isMastered?2:isInProg?2:1,
              className: isInProg ? "hs-inprog-rect" : undefined,
              filter: isMastered ? "url(#node-glow)" : undefined,
            }),
            // Grade chip background
            React.createElement("rect", { x:x+8, y:y+7, width:36, height:14, rx:5, fill: isMastered?"rgba(255,255,255,0.2)":subject.color+"33" }),
            React.createElement("text", { x:x+26, y:y+17, fontSize:8, fill: isMastered?"#fff":subject.accent, textAnchor:"middle", fontWeight:700, fontFamily:"monospace" }, `Gr.${node.grade}`),
            // Status icon
            isMastered
              ? React.createElement("text", { x:x+NODE_W-14, y:y+18, fontSize:13, textAnchor:"middle" }, "⭐")
              : editMode
                ? React.createElement("text", { x:x+NODE_W-14, y:y+18, fontSize:12, fill:"rgba(255,200,80,0.8)", textAnchor:"middle" }, "✎")
                : isInProg
                  ? React.createElement("circle", { cx:x+NODE_W-14, cy:y+13, r:5, fill:subject.accent, opacity:0.9 })
                  : locked
                    ? React.createElement("text", { x:x+NODE_W-14, y:y+18, fontSize:11, textAnchor:"middle" }, "🔒")
                    : React.createElement("circle", { cx:x+NODE_W-14, cy:y+13, r:4, fill:subject.color+"AA" }),
            // Test indicator dot
            hasTest && !editMode && React.createElement("circle", { cx:x+NODE_W-28, cy:y+13, r:3.5, fill:subject.accent, opacity:0.7 }),
            // Label
            React.createElement("foreignObject", { x:x+8, y:y+24, width:NODE_W-20, height:NODE_H-28 },
              React.createElement("div", { xmlns:"http://www.w3.org/1999/xhtml", style:{ color:txtColor, fontSize:11, fontWeight:700, lineHeight:1.35, overflow:"hidden", display:"-webkit-box", WebkitLineClamp:2, WebkitBoxOrient:"vertical", fontFamily:"'Inter','Segoe UI',sans-serif" } }, node.label)
            )
          );
        })
