// Merge curriculum-data.js (tests, resources, updated colors) into RAW_SUBJECTS
function buildSubjects(raw) {
  if (!window.CURRICULUM) return raw;
  const result = {};
  // Merge curriculum data into existing subjects
  for (const [sid, subject] of Object.entries(raw)) {
    const ext = window.CURRICULUM[sid];
    if (!ext) { result[sid] = subject; continue; }
    const base = { ...subject, color: ext.color || subject.color, accent: ext.accent || subject.accent };
    if (!ext.nodes?.length) { result[sid] = base; continue; }
    const extMap = {};
    for (const n of ext.nodes) extMap[n.id] = n;
    result[sid] = {
      ...base,
      nodes: subject.nodes.map(n => ({
        ...n,
        tests: extMap[n.id]?.tests || [],
        resources: extMap[n.id]?.resources || [],
      })),
    };
  }
  // Include new subjects defined entirely in curriculum-data.js
  for (const [sid, ext] of Object.entries(window.CURRICULUM)) {
    if (!result[sid] && ext.nodes?.length) {
      result[sid] = ext;
    }
  }
  return result;
}
const SUBJECTS = buildSubjects(RAW_SUBJECTS);

// Helper: built-in tests + custom questions from localStorage merged
function getNodeAllTests(node, customQuestions) {
  const builtin = (node.tests || []).map((text, i) => ({ id: `builtin_${i}`, text, builtin: true }));
  const custom = (customQuestions[node.id] || []);
  return [...builtin, ...custom];
}

function getWeekSuggestions(childId, data) {
  const inProgress = [], readyNext = [], testReady = [];
  for (const subject of Object.values(SUBJECTS)) {
    const nodes = getSubjectNodes(subject.id, data);
    const progress = data.progress[childId] || {};
    const statuses = computeStatuses(nodes, progress);
    for (const node of nodes) {
      const status = statuses[node.id];
      const hasTest = getNodeAllTests(node, data.questions||{}).length > 0;
      if (status === STATUS.IN_PROGRESS) inProgress.push({ node, subject });
      else if (status === STATUS.UNLOCKED) {
        readyNext.push({ node, subject });
        if (hasTest) testReady.push({ node, subject });
      }
    }
  }
  return { inProgress, readyNext: readyNext.slice(0, 6), testReady: testReady.slice(0, 4) };
}

const STATUS = { LOCKED:"locked", UNLOCKED:"unlocked", IN_PROGRESS:"in_progress", MASTERED:"mastered" };
const STATUS_LABELS = { locked:"Locked", unlocked:"Ready to Learn", in_progress:"In Progress", mastered:"Mastered" };

// ─── LAYOUT ──────────────────────────────────────────────────────────────────
const NODE_W = 162, NODE_H = 70, COL_GAP = 52, ROW_GAP = 50, PAD_X = 32, PAD_Y = 28;

function getSubjectNodes(subjectId, data) {
  const base = SUBJECTS[subjectId];
  const overrides = data.nodeOverrides || {};
  const custom = (data.customNodes || {})[subjectId] || [];
  return [
    ...base.nodes.map(n => ({ ...n, ...(overrides[n.id] || {}) })),
    ...custom,
  ];
}

function getNodePos(node) {
  return { x: PAD_X + node.col * (NODE_W + COL_GAP), y: PAD_Y + node.row * (NODE_H + ROW_GAP) };
}

function buildEdgePath(srcNode, tgtNode) {
  const src = getNodePos(srcNode), tgt = getNodePos(tgtNode);
  const x1 = src.x + NODE_W / 2, y1 = src.y + NODE_H;
  const x2 = tgt.x + NODE_W / 2, y2 = tgt.y;
  const laneY = y1 + (y2 - y1) * 0.5;
  if (srcNode.col === tgtNode.col) {
    const cy = (y1 + y2) / 2;
    return `M${x1},${y1} C${x1},${cy} ${x2},${cy} ${x2},${y2}`;
  }
  const r = 8, hDir = x2 > x1 ? 1 : -1;
  return [`M${x1},${y1}`,`L${x1},${laneY-r}`,`Q${x1},${laneY} ${x1+hDir*r},${laneY}`,`L${x2-hDir*r},${laneY}`,`Q${x2},${laneY} ${x2},${laneY+r}`,`L${x2},${y2}`].join(" ");
}

function computeStatuses(nodes, progress) {
  const mastered = new Set(Object.entries(progress).filter(([k,v]) => v===STATUS.MASTERED && !k.includes("_log") && !k.includes("_score")).map(([k])=>k));
  const result = {};
  for (const node of nodes) {
    const ex = progress[node.id];
    if (ex===STATUS.MASTERED) { result[node.id]=STATUS.MASTERED; continue; }
    if (ex===STATUS.IN_PROGRESS) { result[node.id]=STATUS.IN_PROGRESS; continue; }
    result[node.id] = node.prereqs.every(p => mastered.has(p)) ? STATUS.UNLOCKED : STATUS.LOCKED;
  }
  return result;
}

function statusStroke(status, subject) {
  if (status===STATUS.MASTERED) return subject.accent;
  if (status===STATUS.IN_PROGRESS) return subject.accent;
  if (status===STATUS.UNLOCKED) return subject.color + "99";
  return "rgba(255,255,255,0.08)";
}
function statusFill(status, subject) {
  if (status===STATUS.MASTERED) return subject.color;
  if (status===STATUS.IN_PROGRESS) return subject.color + "55";
  if (status===STATUS.UNLOCKED) return subject.color + "1A";
  return "rgba(8,12,28,0.85)";
}
function statusTextColor(status) {
  if (status===STATUS.MASTERED) return "#fff";
  if (status===STATUS.IN_PROGRESS) return "#fff";
  if (status===STATUS.UNLOCKED) return "#E8EAF0";
  return "rgba(255,255,255,0.28)";
}
// kept for legend
function statusColor(status, subject) {
  if (status===STATUS.MASTERED) return subject.color;
  if (status===STATUS.IN_PROGRESS) return subject.accent;
  if (status===STATUS.UNLOCKED) return subject.color + "88";
  return "#374151";
}

// ─── STORAGE ─────────────────────────────────────────────────────────────────
const STORAGE_KEY = "homeschool_tree_v2";
const DATA_DEFAULTS = {
  children: [{ id:"child1", name:"Child 1", color:"#E06C75" }],
  progress: {}, questions: {}, nodeOverrides: {}, customNodes: {},
  settings: { passingThreshold: 80 },
};

function loadFromCache() {
  try { const r = localStorage.getItem(STORAGE_KEY); if (r) return { ...DATA_DEFAULTS, ...JSON.parse(r) }; } catch {}
  return DATA_DEFAULTS;
}

function saveToCache(d) {
  try { localStorage.setItem(STORAGE_KEY, JSON.stringify(d)); } catch {}
}

async function getSession() {
  if (!window.HS_DB) return null;
  const { data: { session } } = await window.HS_DB.auth.getSession();
  return session;
}

async function loadFromSupabase() {
  const session = await getSession();
  if (!session) return null;
  const { data, error } = await window.HS_DB
    .from("family_data")
    .select("data")
    .eq("user_id", session.user.id)
    .maybeSingle();
  if (error) throw new Error("Load failed: " + error.message);
  if (!data) return null;
  return { ...DATA_DEFAULTS, ...data.data };
}

async function saveToSupabase(d) {
  const session = await getSession();
  if (!session) throw new Error("Not signed in");
  const { error } = await window.HS_DB
    .from("family_data")
    .upsert(
      { user_id: session.user.id, data: d, updated_at: new Date().toISOString() },
      { onConflict: "user_id" }
    );
  if (error) throw new Error("Save failed: " + error.message);
}

async function signOut() {
  if (window.HS_DB) await window.HS_DB.auth.signOut();
  window.location.reload();
}

