              React.createElement("div", { style:{ height:4, borderRadius:2, background:"rgba(255,255,255,0.08)" } },
                React.createElement("div", { style:{ height:"100%", borderRadius:2, width:`${pct}%`, background:`linear-gradient(90deg,${s.color},${s.accent})` } })
              )
            );
          })
        ),

        // Suggestions body
        React.createElement("div", { style:{ padding:"16px 20px 20px", background:"rgba(8,12,28,0.6)" } },

          // In Progress
          suggestions.inProgress.length > 0 && React.createElement("div", { style:{ marginBottom:16 } },
            React.createElement("div", { style:{ fontSize:11, fontWeight:700, color:"rgba(255,255,255,0.35)", textTransform:"uppercase", letterSpacing:"0.08em", marginBottom:8 } }, "▶ Keep Going"),
            React.createElement("div", { style:{ display:"flex", flexDirection:"column", gap:6 } },
              suggestions.inProgress.map(({ node, subject }) =>
