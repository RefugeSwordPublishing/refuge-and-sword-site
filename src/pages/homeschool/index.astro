  const pct = Math.round(masteredCount / nodes.length * 100);

  return React.createElement("div", { style:{ display:"flex", flexDirection:"column", alignItems:"center", padding:"20px 0 80px" } },
    // Progress card
    React.createElement("div", { style:{ width: IS_MOBILE?"calc(100vw - 20px)":"min(580px,92vw)", marginBottom:12, padding: IS_MOBILE?"12px 14px":"16px 20px", borderRadius:14, background:`linear-gradient(135deg, ${subject.color}22, ${subject.accent}10)`, border:`1px solid ${subject.color}35`, boxShadow:`0 4px 24px ${subject.color}18` } },
      React.createElement("div", { style:{ display:"flex", justifyContent:"space-between", alignItems:"center", marginBottom:10 } },
        React.createElement("div", null,
          React.createElement("div", { style:{ fontSize:13, fontWeight:700, color:"#fff" } }, `${child?.name} — ${subject.label}`),
