  const [activeSubject, setActiveSubject] = useState("math");
  const [selectedNode, setSelectedNode] = useState(null);
  const [view, setView] = useState("tree");
  const [addingChild, setAddingChild] = useState(false);
  const [newChildName, setNewChildName] = useState("");
  const [editingChild, setEditingChild] = useState(null);
  const [editChildName, setEditChildName] = useState("");
  const [editMode, setEditMode] = useState(false);
  const [editingNodeId, setEditingNodeId] = useState(null);
  const [syncStatus, setSyncStatus] = useState("loading"); // loading | idle | saving | saved | error
  const [syncError, setSyncError] = useState("");
  const saveTimer = React.useRef(null);
  const COLORS = ["#E06C75","#61AFEF","#98C379","#E5C07B","#C678DD","#56B6C2","#FF8C61"];

  // On mount: sync with Supabase
  // - If cloud has data → use it (canonical truth)
  // - If cloud is empty → push local data up (first-time sync)
  React.useEffect(() => {
    const localData = loadFromCache();
    loadFromSupabase()
      .then(remote => {
        if (remote) {
          // Cloud wins — update local
          setData(remote);
          saveToCache(remote);
          setSyncStatus("idle");
        } else {
          // Nothing in cloud yet — push local data up
          setSyncStatus("saving");
          return saveToSupabase(localData).then(() => setSyncStatus("saved"));
        }
      })
      .catch(err => { setSyncError(err.message); setSyncStatus("error"); });
  }, []);

  const forceSyncNow = (currentData) => {
    setSyncStatus("saving"); setSyncError("");
    saveToSupabase(currentData)
      .then(() => setSyncStatus("saved"))
      .catch(err => { setSyncError(err.message); setSyncStatus("error"); });
  };

  const persist = (next) => {
    setData(next);
    saveToCache(next);
    setSyncStatus("saving"); setSyncError("");
    if (saveTimer.current) clearTimeout(saveTimer.current);
    saveTimer.current = setTimeout(() => {
      saveToSupabase(next)
        .then(() => setSyncStatus("saved"))
        .catch(err => { setSyncError(err.message); setSyncStatus("error"); });
    }, 1500);
  };

  // Fixed: single object, one persist call — no more stale closure race
  const setProgress = (updates) => {
    persist({
      ...data,
      progress: { ...data.progress, [activeChild]: { ...(data.progress[activeChild]||{}), ...updates } },
    });
  };

  const addChild = () => {
    if (!newChildName.trim()) return;
    const id = "child_" + Date.now();
    const color = COLORS[data.children.length % COLORS.length];
    const next = { ...data, children: [...data.children, { id, name: newChildName.trim(), color }] };
    persist(next); setActiveChild(id); setNewChildName(""); setAddingChild(false);
  };

  const removeChild = (cid) => {
    if (data.children.length <= 1) return;
    const next = { ...data, children: data.children.filter(c => c.id !== cid) };
    delete next.progress[cid];
    persist(next);
    if (activeChild === cid) setActiveChild(next.children[0].id);
  };

  const startEditChild = (c) => { setEditingChild(c.id); setEditChildName(c.name); };
  const saveEditChild = () => {
    if (!editChildName.trim()) { setEditingChild(null); return; }
    persist({ ...data, children: data.children.map(c => c.id===editingChild ? { ...c, name: editChildName.trim() } : c) });
    setEditingChild(null);
  };

  const saveNodeOverride = (nodeId, fields) => {
    persist({ ...data, nodeOverrides: { ...(data.nodeOverrides||{}), [nodeId]: { ...((data.nodeOverrides||{})[nodeId]||{}), ...fields } } });
  };

  const addCustomNode = (subjectId, node) => {
    const existing = (data.customNodes||{})[subjectId] || [];
    persist({ ...data, customNodes: { ...(data.customNodes||{}), [subjectId]: [...existing, node] } });
  };

  const deleteCustomNode = (subjectId, nodeId) => {
    const existing = (data.customNodes||{})[subjectId] || [];
    persist({ ...data, customNodes: { ...(data.customNodes||{}), [subjectId]: existing.filter(n=>n.id!==nodeId) } });
    if (selectedNode?.id === nodeId) setSelectedNode(null);
  };

  const saveQuestions = (nodeId, questions) => {
    persist({ ...data, questions: { ...(data.questions||{}), [nodeId]: questions } });
  };

  const saveSettings = (s) => {
    persist({ ...data, settings: { ...(data.settings||{}), ...s } });
  };

  const subject = SUBJECTS[activeSubject];
  const nodes = useMemo(() => getSubjectNodes(activeSubject, data), [activeSubject, data]);
  const childProgress = data.progress[activeChild] || {};
  const statuses = useMemo(() => computeStatuses(nodes, childProgress), [nodes, childProgress]);
  const child = data.children.find(c => c.id === activeChild);
  const masteredCount = Object.values(statuses).filter(s => s===STATUS.MASTERED).length;
  const passingThreshold = (data.settings||{}).passingThreshold ?? 80;

  const editingNode = editingNodeId ? nodes.find(n => n.id === editingNodeId) : null;
  const isCustomNode = (nodeId) => ((data.customNodes||{})[activeSubject]||[]).some(n => n.id === nodeId);

  return React.createElement("div", { style:{ minHeight:"100vh", background:`radial-gradient(ellipse at 25% 15%, ${subject.color}22 0%, transparent 55%), radial-gradient(ellipse at 75% 85%, ${subject.accent}14 0%, transparent 50%), #080C18`, color:"#E8EAF0", fontFamily:"'Inter','Segoe UI',sans-serif", fontSize:14, backgroundAttachment:"fixed" } },

    // TOP BAR
    React.createElement("div", { style:{ display:"flex", alignItems:"center", justifyContent:"space-between", padding: IS_MOBILE ? "10px 12px" : "12px 20px", borderBottom:`1px solid ${subject.color}30`, background:`linear-gradient(90deg, ${subject.color}18 0%, rgba(8,12,28,0.95) 100%)`, position:"sticky", top:0, zIndex:200, backdropFilter:"blur(12px)" } },
      React.createElement("div", { style:{ display:"flex", alignItems:"center", gap:8 } },
        React.createElement("div", { style:{ width: IS_MOBILE?28:32, height: IS_MOBILE?28:32, borderRadius:10, background:`linear-gradient(135deg, ${subject.color}, ${subject.accent})`, display:"flex", alignItems:"center", justifyContent:"center", fontSize: IS_MOBILE?13:16, boxShadow:`0 0 12px ${subject.color}60`, flexShrink:0 } }, subject.icon),
        !IS_MOBILE && React.createElement("div", null,
          React.createElement("div", { style:{ fontWeight:800, fontSize:15, color:"#fff", letterSpacing:"0.02em", lineHeight:1.1 } }, "Homeschool Path"),
