---
const PASSWORD = import.meta.env.HOMESCHOOL_PASSWORD ?? "refuge";
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Homeschool Path — Refuge &amp; Sword</title>
  <meta name="robots" content="noindex, nofollow" />
  <script src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
  <script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
  <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { height: 100%; background: #0F1117; color: #E8EAF0; font-family: 'Inter', 'Segoe UI', sans-serif; }
    #root { height: 100%; }
    #gate {
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      min-height: 100vh; gap: 20px;
    }
    #gate .logo { font-size: 13px; color: rgba(255,255,255,0.3); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 8px; }
    #gate h1 { font-size: 22px; font-weight: 700; color: #fff; }
    #gate p { font-size: 13px; color: rgba(255,255,255,0.4); }
    #gate input {
      padding: 10px 16px; border-radius: 10px; border: 1px solid rgba(255,255,255,0.15);
      background: rgba(255,255,255,0.07); color: #fff; font-size: 15px; width: 240px;
      text-align: center; letter-spacing: 0.05em;
    }
    #gate input:focus { outline: none; border-color: rgba(255,255,255,0.35); }
    #gate button {
      padding: 10px 28px; border-radius: 10px; border: none;
      background: #4A6FA5; color: #fff; font-size: 14px; font-weight: 600; cursor: pointer;
    }
    #gate button:hover { background: #5a7fb5; }
    #gate .error { color: rgba(255,100,100,0.8); font-size: 13px; }
    ::-webkit-scrollbar { width: 6px; height: 6px; }
    ::-webkit-scrollbar-track { background: rgba(255,255,255,0.03); }
    ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.12); border-radius: 3px; }
    input:focus { outline: none; }
    button:focus-visible { outline: 2px solid rgba(255,255,255,0.4); outline-offset: 2px; }
  </style>
</head>
<body>

<!-- Password Gate -->
<div id="gate">
  <div class="logo">Refuge &amp; Sword</div>
  <h1>Homeschool Path</h1>
  <p>Enter the password to continue.</p>
  <input type="password" id="pw-input" placeholder="Password" autocomplete="current-password" />
  <button id="pw-submit">Enter</button>
  <div class="error" id="pw-error" style="display:none">Incorrect password.</div>
</div>

<!-- App mounts here after auth -->
<div id="root" style="display:none;height:100%"></div>

<script define:vars={{ PASSWORD }}>
  const SESSION_KEY = "hs_auth_v1";

  function unlock() {
    document.getElementById("gate").style.display = "none";
    document.getElementById("root").style.display = "block";
  }

  if (sessionStorage.getItem(SESSION_KEY) === "1") {
    unlock();
  }

  document.getElementById("pw-submit").addEventListener("click", attempt);
  document.getElementById("pw-input").addEventListener("keydown", e => { if (e.key === "Enter") attempt(); });

  function attempt() {
    const val = document.getElementById("pw-input").value;
    if (val === PASSWORD) {
      sessionStorage.setItem(SESSION_KEY, "1");
      unlock();
    } else {
      document.getElementById("pw-error").style.display = "block";
      document.getElementById("pw-input").value = "";
      document.getElementById("pw-input").focus();
    }
  }
</script>

