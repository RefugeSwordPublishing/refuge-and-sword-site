    },
      ...Object.values(SUBJECTS).map(s => {
        const sp = data.progress[activeChild] || {};
        const ss = computeStatuses(s.nodes, sp);
        const mc = Object.values(ss).filter(x=>x===STATUS.MASTERED).length;
