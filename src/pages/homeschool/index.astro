function DashboardView({ data, setActiveChild, setActiveSubject, setView }) {
  const INDIGO = "#6366F1";

  return React.createElement("div", { style:{ padding:"20px", maxWidth:900, margin:"0 auto" } },
    React.createElement("div", { style:{ marginBottom:24 } },
      React.createElement("div", { style:{ fontSize:22, fontWeight:800, color:"#fff", marginBottom:4 } }, "This Week"),
      React.createElement("div", { style:{ fontSize:13, color:"rgba(255,255,255,0.4)" } }, "What each child should focus on right now")
    ),

    data.children.map(child => {
      const suggestions = getWeekSuggestions(child.id, data);
      const totalMastered = Object.values(SUBJECTS).reduce((acc, s) => {
        const ns = getSubjectNodes(s.id, data);
        const ss = computeStatuses(ns, data.progress[child.id]||{});
        return acc + Object.values(ss).filter(x=>x===STATUS.MASTERED).length;
      }, 0);
      const totalNodes = Object.values(SUBJECTS).reduce((acc, s) => acc + getSubjectNodes(s.id, data).length, 0);
      const overallPct = Math.round(totalMastered / totalNodes * 100);

      const navigate = (subjectId) => {
        setActiveChild(child.id);
        setActiveSubject(subjectId);
        setView("tree");
      };

      return React.createElement("div", { key: child.id, style:{ marginBottom:24, borderRadius:20, overflow:"hidden", border:`1px solid ${child.color}30`, boxShadow:`0 4px 24px ${child.color}18` } },

        // Child header
        React.createElement("div", { style:{ padding:"16px 20px", background:`linear-gradient(135deg, ${child.color}CC, ${child.color}88)`, display:"flex", justifyContent:"space-between", alignItems:"center" } },
          React.createElement("div", { style:{ display:"flex", alignItems:"center", gap:12 } },
            React.createElement("div", { style:{ width:40, height:40, borderRadius:"50%", background:"rgba(255,255,255,0.25)", display:"flex", alignItems:"center", justifyContent:"center", fontSize:18, fontWeight:800, color:"#fff" } }, child.name[0].toUpperCase()),
            React.createElement("div", null,
              React.createElement("div", { style:{ fontSize:17, fontWeight:800, color:"#fff" } }, child.name),
              React.createElement("div", { style:{ fontSize:11, color:"rgba(255,255,255,0.7)" } }, `${totalMastered} of ${totalNodes} topics mastered overall`)
            ),
