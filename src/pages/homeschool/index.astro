// ─── NODE PANEL ───────────────────────────────────────────────────────────────
function NodePanel({ node, status, subject, onSetProgress, onClose, childProgress, questions, passingThreshold }) {
  const logKey = `${node.id}_log`;
  const scoreKey = `${node.id}_score`;
  const hist = childProgress[logKey] || [];
  const lastScore = childProgress[scoreKey];
  const [tab, setTab] = useState("info");
  const [correct, setCorrect] = useState("");
  const [photoState, setPhotoState] = useState("idle"); // idle | loading | results | error
  const [photoResults, setPhotoResults] = useState(null);
  const [photoError, setPhotoError] = useState("");
  const fileInputRef = React.useRef(null);

  const markStatus = (s) => {
    onSetProgress({
      [node.id]: s,
      [logKey]: [...hist, { status:s, date:new Date().toLocaleDateString() }],
    });
  };

  const submitScore = () => {
    const c = parseInt(correct);
    if (isNaN(c) || c < 0 || c > questions.length) return;
    const pct = questions.length === 0 ? 0 : Math.round((c / questions.length) * 100);
    const passed = pct >= passingThreshold;
    const scoreEntry = { correct:c, total:questions.length, pct, date:new Date().toLocaleDateString(), passed };
    const updates = {
      [scoreKey]: scoreEntry,
      [logKey]: [...hist, { status: passed ? "test_passed" : "test_failed", pct, date:new Date().toLocaleDateString() }],
    };
    if (passed) updates[node.id] = STATUS.MASTERED;
    onSetProgress(updates);
    setCorrect("");
    setPhotoResults(null);
    setPhotoState("idle");
  };

  const handlePhotoChange = async (e) => {
    const file = e.target.files?.[0];
    if (!file) return;
    setPhotoState("loading");
    setPhotoError("");
    setPhotoResults(null);
    try {
      const fd = new FormData();
      fd.append("image", file);
      fd.append("questions", JSON.stringify(questions));
      const res = await fetch("/api/grade-test", { method:"POST", body:fd });
      const json = await res.json();
      if (!res.ok || json.error) throw new Error(json.error || "Grading failed");
      setPhotoResults(json);
      setCorrect(String(json.totalCorrect));
      setPhotoState("results");
    } catch (err) {
      setPhotoError(err.message || "Something went wrong. Enter score manually.");
      setPhotoState("error");
    }
    e.target.value = "";
  };

  const panelTabs = ["info", ...(questions.length > 0 ? ["test"] : [])];

  return React.createElement("div", { style:{ position:"fixed", bottom:0, left:0, right:0, zIndex:300, background:"linear-gradient(0deg,#131720 0%,#1C2232 100%)", borderTop:`2px solid ${subject.color}`, borderRadius:"20px 20px 0 0", padding: IS_MOBILE?"16px 16px 32px":"20px 24px 36px", maxWidth: IS_MOBILE?"100%":640, margin:"0 auto", boxShadow:"0 -24px 60px rgba(0,0,0,0.55)", maxHeight:"80vh", overflowY:"auto" } },

      // Header
      React.createElement("div", { style:{ display:"flex", justifyContent:"space-between", alignItems:"flex-start", marginBottom:12 } },
        React.createElement("div", null,
          React.createElement("div", { style:{ fontSize:10, color:subject.accent, fontWeight:700, textTransform:"uppercase", letterSpacing:"0.1em", marginBottom:4 } }, `Grade ${node.grade}`),
          React.createElement("div", { style:{ fontSize:18, fontWeight:700, color:"#fff" } }, node.label),
          React.createElement("div", { style:{ fontSize:12, marginTop:4, color: status===STATUS.MASTERED?subject.accent:status===STATUS.IN_PROGRESS?"#E5C07B":"rgba(255,255,255,0.4)", fontWeight:600 } },
            status===STATUS.MASTERED ? "★ Mastered" : status===STATUS.IN_PROGRESS ? "▶ In Progress" : "Ready to Start"
          ),
        ),
        React.createElement("button", { onClick:onClose, style:{ background:"rgba(255,255,255,0.08)", border:"none", color:"rgba(255,255,255,0.45)", borderRadius:8, padding:"6px 10px", cursor:"pointer", fontSize:16 } }, "✕")
      ),

      // Tabs
      panelTabs.length > 1 && React.createElement("div", { style:{ display:"flex", gap:4, marginBottom:16 } },
        panelTabs.map(t => React.createElement("button", { key:t, onClick:()=>setTab(t), style:{ padding:"5px 14px", borderRadius:8, border:"none", background:tab===t?"rgba(255,255,255,0.12)":"transparent", color:tab===t?"#fff":"rgba(255,255,255,0.4)", fontWeight:tab===t?700:400, fontSize:12, cursor:"pointer" } }, t==="info"?"Info":"Test"))
      ),

      // INFO TAB
      tab==="info" && React.createElement("div", null,
        React.createElement("p", { style:{ color:"rgba(255,255,255,0.58)", fontSize:13, lineHeight:1.65, marginBottom:14 } }, node.desc),
        (node.resources||[]).length > 0 && React.createElement("div", { style:{ marginBottom:16 } },
