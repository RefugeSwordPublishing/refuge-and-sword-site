              React.createElement("input", { value:editChildName, onChange:e=>setEditChildName(e.target.value), onKeyDown:e=>{ if(e.key==="Enter") saveEditChild(); if(e.key==="Escape") setEditingChild(null); }, onBlur:saveEditChild, autoFocus:true, style:{ padding:"5px 10px", borderRadius:16, border:`1px solid ${c.color}`, background:"rgba(255,255,255,0.1)", color:"#fff", fontSize:13, width:110 } })
            )
